<Window x:Class="it2a_databaze.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:it2a_databaze"
        mc:Ignorable="d"
        Title="MainWidnow" Height="500" Width="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- DataGrid -->
        <DataGrid x:Name="dgKopacky"
                  ItemsSource="{Binding ModelyKopacek}"
                  Grid.Column="0"
                  Margin="0,0,10,0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow" SelectionChanged="dgKopacky_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Značka" Binding="{Binding Znacka}" Width="*"/>
                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*"/>
                <DataGridTextColumn Header="Barva" Binding="{Binding Barva}" Width="100"/>
                <DataGridTextColumn Header="Cena" Binding="{Binding Cena}" Width="100"/>
                <DataGridCheckBoxColumn Header="Používám" Binding="{Binding AktualnePouzivam}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Pravý panel -->
        <StackPanel Grid.Column="1">

            <TextBlock Text="Evidence kopaček"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Značka:"/>
            <TextBox x:Name="tbZnacka" Margin="0,0,0,8" TextChanged="tbZnacka_TextChanged"/>

            <TextBlock Text="Model:"/>
            <TextBox x:Name="tbModel" Margin="0,0,0,8" TextChanged="tbModel_TextChanged"/>

            <TextBlock Text="Barva:"/>
            <TextBox x:Name="tbBarva" Margin="0,0,0,8" TextChanged="tbBarva_TextChanged"/>

            <TextBlock Text="Cena:"/>
            <TextBox x:Name="tbCena" Margin="0,0,0,8" TextChanged="tbCena_TextChanged"/>

            <CheckBox x:Name="cbPouzivam"
                      Content="Aktuálně používám"
                      Margin="0,0,0,10" Checked="cbPouzivam_Checked"/>

            <Button Content="Přidat kopačky" Margin="0,5" Click="Button_PridatKopacky"/>
            <Button Content="Načíst vybrané do formuláře" Margin="0,5" Click="Button_NacistDoFormulare"/>
            <Button Content="Upravit vybrané kopačky" Margin="0,5" Click="Button_UpravitVybrane"/>
            <Button Content="Smazat vybrané kopačky" Margin="0,5" Click="Button_SmazatVybrane"/>
            <Button Content="Vyčistit formulář" Margin="0,5" Click="Button_VycistitFormular"/>

        </StackPanel>
    </Grid>
</Window>